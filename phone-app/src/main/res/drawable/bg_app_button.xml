<?xml version="1.0" encoding="utf-8"?>
<!-- Raised rounded-rectangle button (custom app shortcuts). Same domed-gradient
     treatment as bg_circle_button; pair with android:elevation on the view. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#131B36"
                android:endColor="#2A3A64" />
            <corners android:radius="18dp" />
            <stroke android:width="1dp" android:color="#1FFFFFFF" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#2C3C68"
                android:endColor="#141C38" />
            <corners android:radius="18dp" />
            <stroke android:width="1dp" android:color="#26FFFFFF" />
        </shape>
    </item>
</selector>
