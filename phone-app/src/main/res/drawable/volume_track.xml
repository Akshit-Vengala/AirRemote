<?xml version="1.0" encoding="utf-8"?>
<!-- SeekBar progressDrawable: a rounded "pill" track. Background is the muted
     navy groove; the filled portion is an accent-blue gradient. Track thickness
     is set by the <size> height here + maxHeight on the SeekBar. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape android:shape="rectangle">
            <solid android:color="#1A2547" />
            <corners android:radius="7dp" />
            <size android:height="14dp" />
            <stroke android:width="1dp" android:color="#22FFFFFF" />
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <clip>
            <shape android:shape="rectangle">
                <gradient
                    android:angle="0"
                    android:startColor="#3F7DEB"
                    android:endColor="#6FA8FF" />
                <corners android:radius="7dp" />
                <size android:height="14dp" />
            </shape>
        </clip>
    </item>
</layer-list>
