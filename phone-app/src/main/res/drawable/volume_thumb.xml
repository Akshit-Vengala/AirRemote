<?xml version="1.0" encoding="utf-8"?>
<!-- SeekBar thumb: a raised round knob. Light dome with an accent ring so it
     reads as a grabbable handle sitting above the track. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <gradient
        android:angle="270"
        android:startColor="#FFFFFF"
        android:endColor="#D5E2FF" />
    <size android:width="26dp" android:height="26dp" />
    <stroke android:width="2dp" android:color="#4C8DFF" />
</shape>
