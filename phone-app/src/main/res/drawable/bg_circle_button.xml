<?xml version="1.0" encoding="utf-8"?>
<!-- Raised circular button. The top→bottom gradient (light top, dark bottom)
     fakes a domed/extruded surface; pair with android:elevation on the view for
     the drop shadow. Pressed state inverts the gradient so it looks pushed in. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:startColor="#131B36"
                android:endColor="#2A3A64" />
            <stroke android:width="1dp" android:color="#1FFFFFFF" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:startColor="#2C3C68"
                android:endColor="#141C38" />
            <stroke android:width="1dp" android:color="#26FFFFFF" />
        </shape>
    </item>
</selector>
