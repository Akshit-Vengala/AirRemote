# EditorConfig — consistent formatting across IDEs/editors.
# https://editorconfig.org   (Android Studio / IntelliJ honor this natively.)
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
max_line_length = 100

# Kotlin — follow the official Kotlin style guide (ktlint-compatible).
[*.{kt,kts}]
indent_size = 4
ktlint_code_style = official

# Android XML resources are conventionally indented 4 spaces.
[*.xml]
indent_size = 4

[*.{yml,yaml,json,toml}]
indent_size = 2

# Windows batch files keep CRLF (see .gitattributes).
[*.{bat,cmd,ps1}]
end_of_line = crlf

# Markdown — trailing whitespace can be meaningful (hard line breaks).
[*.md]
trim_trailing_whitespace = false
